        "platforms": ["instagram", "threads", "youtube"],
        "cta_primary": "inema.club — grátis para começar",
        "cta_secondary": "inema.vip — R$ 35/mês, comunidade ativa",
        "tone": "emocional, inspirador, empoderador, sem elitismo",
        "language": "pt-BR"
      },
      "platform_rules": {
        "instagram": {
          "structure": "hook emocional → benefício → CTA → linha em branco → hashtags",
          "max_sentences": 4,
          "emojis": 2,
          "hashtag_count": "5-8",
          "cta_required": true,
          "hashtag_placement": "comentário (não na legenda)"
        },
        "threads": {
          "structure": "frase provocadora → insight → CTA com URL",
          "max_chars": 500,
          "hashtag_count": "2-3"
        },
        "youtube": {
          "title_length": "60-70 caracteres",
          "title_no_emojis": true,
          "description_sentences": "2-3",
          "description_ends_with_cta": true,
          "tag_count": "6-8"
        }
      },
      "outputs": {
        "folder": "prj/inema/outputs/dia_das_maes_2026-05-10/copy",
        "files": [
          "instagram_caption.txt",
          "threads_post.txt",
          "youtube_metadata.json",
          "copy_output.json"
        ]
      }
    },

    "distribution": {
