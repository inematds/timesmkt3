        "brand_colors": {
          "primary": "#0099FF",
          "dark": "#0D0D0D",
          "accent": "#00FF88",
          "white": "#FFFFFF"
        },
        "copy": {
          "headline": "Mãe que aprende",
          "subtext": "O presente mais poderoso tem URL: inema.club",
          "cta": "Comece grátis"
